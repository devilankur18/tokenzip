{
  "name": "tokenzip",
  "version": "1.0.0",
  "description": "TokenZip — Reduce AI coding token costs by 90% with a persistent, queryable code intelligence graph that gives agents deep repo awareness across files, symbols, dependencies, and docs.",
  "license": "MIT",
  "author": "Ankur Agarwal",
  "homepage": "https://github.com/ankur/tokenzip",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ankur/tokenzip.git"
  },
  "keywords": [
    "mcp",
    "ai",
    "code-search",
    "knowledge-graph",
    "surrealdb",
    "codebase",
    "copilot",
    "cli"
  ],
  "type": "module",
  "bin": {
    "tokenzip": "./dist/cli/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build",
    "start": "node dist/cli/index.js",
    "bench:setup": "bash bench/setup.sh",
    "bench:savings": "node bench/token-savings.js",
    "bench:mcp": "node bench/mcp-test.js",
    "bench": "npm run bench:setup && npm run bench:savings && npm run bench:mcp"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@surrealdb/node": "^3.0.3",
    "commander": "^14.0.3",
    "simple-git": "^3.36.0",
    "surrealdb": "^2.0.3",
    "tree-sitter-typescript": "^0.23.2",
    "web-tree-sitter": "^0.26.8"
  },
  "devDependencies": {
    "@types/node": "^25.6.2",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.6"
  }
}